# ============================================================================
# ARC — Secrets Configuration
# ============================================================================
# Copy this file to ~/.arc/secrets.env and fill in your values.
# IMPORTANT: Always use single quotes for API key values.
# NEVER commit the real secrets.env file.
# ============================================================================

# --- Kraken API ---
KRAKEN_API_KEY='your_kraken_api_key_here'
KRAKEN_API_SECRET='your_kraken_api_secret_here'

# --- Pushover Notifications ---
PUSHOVER_USER_KEY='your_pushover_user_key_here'
PUSHOVER_API_TOKEN='your_pushover_api_token_here'

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN='your_telegram_bot_token_here'
TELEGRAM_CHAT_ID='your_telegram_chat_id_here'
